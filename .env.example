# ═══════════════════════════════════════════════════
# EduNexus — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ─── Supabase ───────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # SERVER ONLY — never expose to client

# ─── App ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EduNexus

# ─── Email (Resend) — Phase 2 ───────────────────────
# RESEND_API_KEY=re_your-api-key-here
# EMAIL_FROM=noreply@edunexus.app

# ─── Storage ────────────────────────────────────────
# Supabase storage is configured automatically via SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://your-project-ref.supabase.co/storage/v1

# ─── Vercel ─────────────────────────────────────────
# Set automatically by Vercel in production
# VERCEL_URL=your-app.vercel.app

# ─── Testing ────────────────────────────────────────
# PLAYWRIGHT_BASE_URL=http://localhost:3000
